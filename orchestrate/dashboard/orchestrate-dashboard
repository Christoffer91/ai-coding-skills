#!/usr/bin/env python3
"""orchestrate-dashboard — ONE local page for every /orchestrate run on this machine.

Reads run status from ~/.orchestrate/runs/*.json (written by `orchestrate-status`),
serves an aggregate dashboard, and accepts click-to-answer gate responses
(POST /api/answer -> ~/.orchestrate/answers/<id>.json, which the run polls).

Usage:  orchestrate-dashboard [--port 4600]      (env: ORCH_DASH_PORT)
Binds to 127.0.0.1 only. No dependencies (Python 3 stdlib).
"""
import http.server, socketserver, json, os, glob, time, argparse, urllib.parse, threading, subprocess, signal, re

HOME = os.path.expanduser("~")
BASE = os.path.join(HOME, ".orchestrate")
RUNS = os.path.join(BASE, "runs")
ANS  = os.path.join(BASE, "answers")
HERE = os.path.dirname(os.path.abspath(__file__))
HTML = os.path.join(HERE, "dashboard.html")
STALE_SECS = int(os.environ.get("ORCH_STALE_SECS", "75"))  # no update for this long => "stalled?"
RETENTION_SECS = 7 * 24 * 60 * 60


def pid_alive(pid):
    """True=running, False=gone, None=unknown/not-tracked."""
    if not pid:
        return None
    try:
        os.kill(int(pid), 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True   # exists, just not ours to signal
    except Exception:
        return None


def load_runs():
    out = []
    now = int(time.time())
    for f in sorted(glob.glob(os.path.join(RUNS, "*.json"))):
        try:
            with open(f) as fh:
                r = json.load(fh)
        except Exception:
            continue
        af = os.path.join(ANS, os.path.basename(f))
        if os.path.exists(af):
            try:
                with open(af) as fh:
                    r["answered"] = json.load(fh)
            except Exception:
                pass
        # --- liveness: is this run actually still running? ---
        age = now - int(r.get("updatedAt", now))
        r["staleSecs"] = age
        alive = pid_alive(r.get("pid"))
        r["pidAlive"] = alive
        status = r.get("status")
        if status == "handoff":
            r["health"] = "handoff"
        elif status in ("failed", "fail"):
            r["health"] = "failed"
        elif status == "rejected":
            r["health"] = "rejected"
        elif status == "done":
            r["health"] = "done"
        elif r.get("gate") and not r.get("answered"):
            r["health"] = "waiting"       # blocked on you, not a liveness concern
        elif alive is False:
            r["health"] = "exited"        # the worker process is gone
        elif age > STALE_SECS:
            r["health"] = "stale"         # no update in a while — long step or a hang
        else:
            r["health"] = "live"          # updated recently / worker alive
        out.append(r)
    return out


def process_start(pid):
    try:
        return subprocess.run(["ps", "-o", "lstart=", "-p", str(int(pid))], capture_output=True,
                              text=True, timeout=3).stdout.strip() or None
    except Exception:
        return None


def process_cwd(pid):
    try:
        out = subprocess.run(["lsof", "-a", "-p", str(int(pid)), "-d", "cwd", "-Fn"],
                             capture_output=True, text=True, timeout=3).stdout
        return next((line[1:] for line in out.splitlines() if line.startswith("n")), None)
    except Exception:
        return None


def process_matches(record):
    """Match a PID to its recorded start token and cwd so PID reuse fails closed."""
    pid = record.get("pid")
    expected_start = record.get("pidStart", record.get("startedAt"))
    expected_cwd = record.get("pidCwd", record.get("cwd"))
    if not (pid and expected_start and expected_cwd):
        return False
    actual_start = process_start(pid)
    actual_cwd = process_cwd(pid)
    return (actual_start == expected_start and actual_cwd is not None
            and os.path.realpath(actual_cwd) == os.path.realpath(expected_cwd))


def direct_children(pid):
    try:
        out = subprocess.run(["pgrep", "-P", str(int(pid))], capture_output=True,
                             text=True, timeout=3).stdout
        return [int(p) for p in out.split() if p.isdigit()]
    except Exception:
        return []


def kill_recorded_process(record):
    if not process_matches(record):
        return False
    pid = int(record["pid"])
    try:
        pgid = os.getpgid(pid)
        if pgid == pid and int(record.get("pgid") or -1) == pid:
            os.killpg(pgid, signal.SIGKILL)
        else:
            for child in direct_children(pid):
                try: os.kill(child, signal.SIGKILL)
                except Exception: pass
            os.kill(pid, signal.SIGKILL)
        return True
    except Exception:
        return False


def reap(run):
    """Kill only identity-matched processes recorded for this run."""
    worker = run.get("worker")
    if worker:
        kill_recorded_process(worker)
    return kill_recorded_process(run)


def is_linked_worktree(cwd):
    try:
        git_dir = subprocess.run(["git", "-C", cwd, "rev-parse", "--path-format=absolute", "--git-dir"],
                                 capture_output=True, text=True, timeout=4, check=True).stdout.strip()
        common = subprocess.run(["git", "-C", cwd, "rev-parse", "--path-format=absolute", "--git-common-dir"],
                                capture_output=True, text=True, timeout=4, check=True).stdout.strip()
        return os.path.realpath(git_dir) != os.path.realpath(common)
    except Exception:
        return False


def validate_restart(r):
    cwd, topic, driver = r.get("cwd"), r.get("topic"), r.get("driver")
    restart = r.get("restart") or {}
    plan = restart.get("plan")
    if not restart.get("dedicatedWorktree"):
        return "automatic restart is restricted to a recorded dedicated worktree"
    if not (cwd and os.path.isdir(cwd) and is_linked_worktree(cwd)):
        return "recorded dedicated worktree is missing or invalid"
    root = os.path.realpath(cwd)
    if not (topic and re.fullmatch(r"[a-z0-9][a-z0-9._-]{0,60}", topic)):
        return "recorded topic is invalid"
    if not (driver and os.path.isfile(driver) and os.path.basename(driver) == "orchestrate.sh"
            and os.path.commonpath([root, os.path.realpath(driver)]) == root):
        return "recorded driver is not inside the dedicated worktree"
    if not (plan and os.path.isfile(plan)
            and os.path.commonpath([root, os.path.realpath(plan)]) == root):
        return "recorded plan is not inside the dedicated worktree"
    return None


def restart_or_kill(rid, kill_only=False):
    """Reap a stalled/dead run and (unless kill_only) relaunch its driver restart-safe."""
    if not rid:
        return (400, json.dumps({"error": "id required"}))
    try:
        with open(os.path.join(RUNS, rid + ".json")) as fh:
            r = json.load(fh)
    except Exception:
        return (404, json.dumps({"error": "no such run"}))
    if kill_only:
        reap(r)
        return (200, json.dumps({"ok": True, "killed": True}))
    error = validate_restart(r)
    if error:
        return (409, json.dumps({"error": error}))
    cwd, topic, driver = r["cwd"], r["topic"], r["driver"]
    plan = r["restart"]["plan"]
    reap(r)
    os.makedirs(os.path.join(BASE, "logs"), exist_ok=True)
    logf = open(os.path.join(BASE, "logs", rid + ".log"), "ab")
    env = dict(os.environ)
    for key, value in (r.get("restart", {}).get("env") or {}).items():
        if key.startswith("ORCH_"):
            env[key] = str(value)
    env.update({"ORCH_RESTART": "1", "ORCH_WORKTREE": "0", "ORCH_DEDICATED_WORKTREE": "1"})
    try:
        subprocess.Popen([driver, topic, plan], cwd=cwd, env=env, stdout=logf, stderr=logf, start_new_session=True)
    except Exception as e:
        logf.close()
        return (500, json.dumps({"error": f"launch failed: {e}"}))
    logf.close()
    return (200, json.dumps({"ok": True, "restarted": topic}))


def cleanup_retained_runs(now=None):
    """Remove terminal run/answer files older than seven days."""
    now = int(time.time()) if now is None else int(now)
    for filename in glob.glob(os.path.join(RUNS, "*.json")):
        try:
            with open(filename) as fh:
                run = json.load(fh)
        except Exception:
            continue
        if run.get("status") not in ("done", "failed", "fail", "rejected"):
            continue
        if now - int(run.get("updatedAt", now)) <= RETENTION_SECS:
            continue
        try: os.remove(filename)
        except OSError: pass
        answer = os.path.join(ANS, os.path.basename(filename))
        try: os.remove(answer)
        except OSError: pass


class Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code, body, ctype="application/json"):
        b = body if isinstance(body, bytes) else str(body).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(b)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(b)

    def do_GET(self):
        p = urllib.parse.urlparse(self.path).path
        if p in ("/", "/index.html"):
            try:
                with open(HTML, "rb") as fh:
                    self._send(200, fh.read(), "text/html; charset=utf-8")
            except FileNotFoundError:
                self._send(500, "dashboard.html not found next to this script", "text/plain")
        elif p == "/api/runs":
            self._send(200, json.dumps(load_runs()))
        elif p == "/api/health":
            self._send(200, json.dumps({"ok": True, "runs": len(load_runs())}))
        else:
            self._send(404, "not found", "text/plain")

    def do_POST(self):
        p = urllib.parse.urlparse(self.path).path
        try:
            n = int(self.headers.get("Content-Length", 0))
            data = json.loads(self.rfile.read(n) or b"{}")
        except Exception:
            return self._send(400, json.dumps({"error": "bad json"}))
        rid = os.path.basename(str(data.get("id", "")))  # sanitize: no path traversal
        if p == "/api/answer":
            if not rid:
                return self._send(400, json.dumps({"error": "id required"}))
            os.makedirs(ANS, exist_ok=True)
            with open(os.path.join(ANS, rid + ".json"), "w") as fh:
                json.dump({"choice": data.get("choice"), "at": int(time.time())}, fh)
            self._send(200, json.dumps({"ok": True}))
        elif p == "/api/restart":
            self._send(*restart_or_kill(rid))
        elif p == "/api/kill":
            self._send(*restart_or_kill(rid, kill_only=True))
        else:
            self._send(404, "not found", "text/plain")

    def log_message(self, *a):  # quiet
        pass


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", type=int, default=int(os.environ.get("ORCH_DASH_PORT", "4600")))
    ap.add_argument("--no-exit-with-parent", action="store_true",
                    help="keep running even after the launching process (e.g. Claude Desktop) exits")
    args = ap.parse_args()
    # Self-terminate when our parent process goes away (e.g. Claude Desktop closes),
    # unless we were started already-detached (ppid==1) or told to stay up.
    ppid0 = os.getppid()
    if not args.no_exit_with_parent and ppid0 != 1:
        def _watch_parent():
            while True:
                time.sleep(3)
                if os.getppid() != ppid0:
                    os._exit(0)
        threading.Thread(target=_watch_parent, daemon=True).start()
    os.makedirs(RUNS, exist_ok=True)
    os.makedirs(ANS, exist_ok=True)
    cleanup_retained_runs()
    socketserver.TCPServer.allow_reuse_address = True
    with socketserver.TCPServer(("127.0.0.1", args.port), Handler) as srv:
        print(f"orchestrate dashboard → http://localhost:{args.port}   (runs: {RUNS})")
        try:
            srv.serve_forever()
        except KeyboardInterrupt:
            pass


if __name__ == "__main__":
    main()
