#!/usr/bin/env python3
"""orchestrate-dashboard — ONE local page for every /orchestrate run on this machine.

Reads run status from ~/.orchestrate/runs/*.json (written by `orchestrate-status`),
serves an aggregate dashboard, and accepts click-to-answer gate responses
(POST /api/answer -> ~/.orchestrate/answers/<id>.json, which the run polls).

Usage:  orchestrate-dashboard [--port 4600]      (env: ORCH_DASH_PORT)
Binds to 127.0.0.1 only. No dependencies (Python 3 stdlib).
"""
import http.server, socketserver, json, os, glob, time, argparse, urllib.parse, threading, subprocess, signal, re, sys
from pathlib import Path

HOME = os.path.expanduser("~")
BASE = os.path.join(HOME, ".orchestrate")
RUNS = os.path.join(BASE, "runs")
ANS  = os.path.join(BASE, "answers")
# realpath, not abspath: the server must find dashboard.html (and overrides.py)
# next to the REAL script even when launched via a ~/.local/bin symlink.
HERE = os.path.dirname(os.path.realpath(__file__))
if HERE not in sys.path:
    sys.path.insert(0, HERE)
import overrides
import thresholds
HTML = os.path.join(HERE, "dashboard.html")
STALE_SECS = thresholds.DRIVER_STALE_SECS          # streaming driver silent this long => "stalled"
SESSION_STALE_SECS = thresholds.SESSION_QUIET_SECS  # model run silent this long => neutral "quiet"
RETENTION_SECS = 7 * 24 * 60 * 60


def pid_alive(pid):
    """True=running, False=gone, None=unknown/not-tracked."""
    if not pid:
        return None
    try:
        os.kill(int(pid), 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True   # exists, just not ours to signal
    except Exception:
        return None


def load_runs():
    out = []
    now = int(time.time())
    for f in sorted(glob.glob(os.path.join(RUNS, "*.json"))):
        try:
            with open(f) as fh:
                r = json.load(fh)
        except Exception:
            continue
        af = os.path.join(ANS, os.path.basename(f))
        if os.path.exists(af):
            try:
                with open(af) as fh:
                    r["answered"] = json.load(fh)
            except Exception:
                pass
        # --- liveness: is this run actually still running? ---
        age = now - int(r.get("updatedAt", now))
        r["staleSecs"] = age
        alive = pid_alive(r.get("pid"))
        r["pidAlive"] = alive
        status = r.get("status")
        if status == "handoff":
            r["health"] = "handoff"
        elif status in ("failed", "fail"):
            r["health"] = "failed"
        elif status == "rejected":
            r["health"] = "rejected"
        elif status == "done":
            r["health"] = "done"
        elif r.get("steps") and all(s.get("state") == "done" for s in r["steps"]):
            r["health"] = "done"          # every step done: finished round missing its terminal emit
        elif r.get("gate") and not r.get("answered"):
            r["health"] = "waiting"       # blocked on you, not a liveness concern
        elif alive is False:
            r["health"] = "exited"        # the worker process is gone
        elif r.get("pid") and age > STALE_SECS:
            r["health"] = "stale"         # a streaming driver went silent — evidence of a real hang
        elif not r.get("pid") and age > SESSION_STALE_SECS:
            # Model-driven run (Codex goal / in-session) that emits only at transitions. Silence is
            # missing telemetry, not proof of a hang — say so honestly instead of crying "stalled".
            r["health"] = "quiet"
        else:
            r["health"] = "live"          # updated recently / worker alive
        if r["health"] in ("stale", "exited", "failed"):
            restart_reason = validate_restart(r)
        else:
            restart_reason = "automatic restart is offered only for stalled, exited, or failed runs"
        r["restartable"] = restart_reason is None
        r["restartReason"] = restart_reason
        r["hasConsole"] = console_log_for(r) is not None
        out.append(r)
    return out


def process_start(pid):
    try:
        return subprocess.run(["ps", "-o", "lstart=", "-p", str(int(pid))], capture_output=True,
                              text=True, timeout=3).stdout.strip() or None
    except Exception:
        return None


def process_cwd(pid):
    try:
        out = subprocess.run(["lsof", "-a", "-p", str(int(pid)), "-d", "cwd", "-Fn"],
                             capture_output=True, text=True, timeout=3).stdout
        return next((line[1:] for line in out.splitlines() if line.startswith("n")), None)
    except Exception:
        return None


def process_matches(record):
    """Match a PID to its recorded start token and cwd so PID reuse fails closed."""
    pid = record.get("pid")
    expected_start = record.get("pidStart", record.get("startedAt"))
    expected_cwd = record.get("pidCwd", record.get("cwd"))
    if not (pid and expected_start and expected_cwd):
        return False
    actual_start = process_start(pid)
    actual_cwd = process_cwd(pid)
    return (actual_start == expected_start and actual_cwd is not None
            and os.path.realpath(actual_cwd) == os.path.realpath(expected_cwd))


def direct_children(pid):
    try:
        out = subprocess.run(["pgrep", "-P", str(int(pid))], capture_output=True,
                             text=True, timeout=3).stdout
        return [int(p) for p in out.split() if p.isdigit()]
    except Exception:
        return []


def kill_recorded_process(record):
    if not process_matches(record):
        return False
    pid = int(record["pid"])
    try:
        pgid = os.getpgid(pid)
        if pgid == pid and int(record.get("pgid") or -1) == pid:
            os.killpg(pgid, signal.SIGKILL)
        else:
            for child in direct_children(pid):
                try: os.kill(child, signal.SIGKILL)
                except Exception: pass
            os.kill(pid, signal.SIGKILL)
        return True
    except Exception:
        return False


def reap(run):
    """Kill only identity-matched processes recorded for this run."""
    worker = run.get("worker")
    if worker:
        kill_recorded_process(worker)
    return kill_recorded_process(run)


def is_linked_worktree(cwd):
    try:
        git_dir = subprocess.run(["git", "-C", cwd, "rev-parse", "--path-format=absolute", "--git-dir"],
                                 capture_output=True, text=True, timeout=4, check=True).stdout.strip()
        common = subprocess.run(["git", "-C", cwd, "rev-parse", "--path-format=absolute", "--git-common-dir"],
                                capture_output=True, text=True, timeout=4, check=True).stdout.strip()
        return os.path.realpath(git_dir) != os.path.realpath(common)
    except Exception:
        return False


def validate_restart(r):
    cwd, topic, driver = r.get("cwd"), r.get("topic"), r.get("driver")
    restart = r.get("restart") or {}
    plan = restart.get("plan")
    if not restart.get("dedicatedWorktree"):
        return "automatic restart is restricted to a recorded dedicated worktree"
    if not (cwd and os.path.isdir(cwd) and is_linked_worktree(cwd)):
        return "recorded dedicated worktree is missing or invalid"
    root = os.path.realpath(cwd)
    if not (topic and re.fullmatch(r"[a-z0-9][a-z0-9._-]{0,60}", topic)):
        return "recorded topic is invalid"
    if not (driver and os.path.isfile(driver) and os.path.basename(driver) == "orchestrate.sh"
            and os.path.commonpath([root, os.path.realpath(driver)]) == root):
        return "recorded driver is not inside the dedicated worktree"
    if not (plan and os.path.isfile(plan)
            and os.path.commonpath([root, os.path.realpath(plan)]) == root):
        return "recorded plan is not inside the dedicated worktree"
    return None


def restart_or_kill(rid, kill_only=False):
    """Reap a stalled/dead run and (unless kill_only) relaunch its driver restart-safe."""
    if not rid:
        return (400, json.dumps({"error": "id required"}))
    try:
        with open(os.path.join(RUNS, rid + ".json")) as fh:
            r = json.load(fh)
    except Exception:
        return (404, json.dumps({"error": "no such run"}))
    if kill_only:
        reap(r)
        return (200, json.dumps({"ok": True, "killed": True}))
    error = validate_restart(r)
    if error:
        return (409, json.dumps({"error": error}))
    cwd, topic, driver = r["cwd"], r["topic"], r["driver"]
    plan = r["restart"]["plan"]
    reap(r)
    os.makedirs(os.path.join(BASE, "logs"), exist_ok=True)
    logf = open(os.path.join(BASE, "logs", rid + ".log"), "ab")
    env = dict(os.environ)
    for key, value in (r.get("restart", {}).get("env") or {}).items():
        if key.startswith("ORCH_"):
            env[key] = str(value)
    env.update({"ORCH_RESTART": "1", "ORCH_WORKTREE": "0", "ORCH_DEDICATED_WORKTREE": "1"})
    try:
        subprocess.Popen([driver, topic, plan], cwd=cwd, env=env, stdout=logf, stderr=logf, start_new_session=True)
    except Exception as e:
        logf.close()
        return (500, json.dumps({"error": f"launch failed: {e}"}))
    logf.close()
    return (200, json.dumps({"ok": True, "restarted": topic}))


def cleanup_retained_runs(now=None):
    """Remove terminal run/answer files older than seven days."""
    now = int(time.time()) if now is None else int(now)
    for filename in glob.glob(os.path.join(RUNS, "*.json")):
        try:
            with open(filename) as fh:
                run = json.load(fh)
        except Exception:
            continue
        if run.get("status") not in ("done", "failed", "fail", "rejected"):
            continue
        if now - int(run.get("updatedAt", now)) <= RETENTION_SECS:
            continue
        try: os.remove(filename)
        except OSError: pass
        answer = os.path.join(ANS, os.path.basename(filename))
        try: os.remove(answer)
        except OSError: pass


def console_log_for(record):
    """This run's own console log: recorded consoleLog -> metrics.log -> its artifacts dir.
    Deliberately NO global/TMPDIR fallback — showing another run's log is worse than showing none."""
    for rec in (record.get("consoleLog"), (record.get("metrics") or {}).get("log")):
        if rec and os.path.isfile(rec):
            return rec
    art = os.path.join(BASE, "artifacts", os.path.basename(record.get("id") or ""))
    logs = sorted(glob.glob(os.path.join(art, "*.log")), key=os.path.getmtime, reverse=True)
    return logs[0] if logs else None


def resolve_console_log(rid):
    if not rid:
        return None
    try:
        with open(os.path.join(RUNS, os.path.basename(rid) + ".json")) as fh:
            r = json.load(fh)
    except Exception:
        return None
    return console_log_for(r)


class Handler(http.server.BaseHTTPRequestHandler):
    def _send(self, code, body, ctype="application/json"):
        b = body if isinstance(body, bytes) else str(body).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(b)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(b)

    def do_GET(self):
        p = urllib.parse.urlparse(self.path).path
        if p in ("/", "/index.html"):
            try:
                with open(HTML, "rb") as fh:
                    self._send(200, fh.read(), "text/html; charset=utf-8")
            except FileNotFoundError:
                self._send(500, "dashboard.html not found next to this script", "text/plain")
        elif p == "/watch":
            try:
                with open(os.path.join(HERE, "watch.html"), "rb") as fh:
                    self._send(200, fh.read(), "text/html; charset=utf-8")
            except FileNotFoundError:
                self._send(500, "watch.html not found next to this script", "text/plain")
        elif p in ("/log", "/console"):
            try:
                with open(os.path.join(HERE, "log.html"), "rb") as fh:
                    self._send(200, fh.read(), "text/html; charset=utf-8")
            except FileNotFoundError:
                self._send(500, "log.html not found next to this script", "text/plain")
        elif p in ("/api/log", "/api/console"):
            q = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
            rid = os.path.basename((q.get("id") or [""])[0])
            tail = min(int((q.get("tail") or ["65536"])[0]), 512 * 1024)
            path = resolve_console_log(rid)
            if not path:
                return self._send(404, json.dumps({"error": "no console log found for this run"}))
            try:
                st = os.stat(path)
                with open(path, "rb") as fh:
                    if st.st_size > tail:
                        fh.seek(st.st_size - tail)
                    text = fh.read().decode("utf-8", "replace")
                self._send(200, json.dumps({"path": path, "size": st.st_size,
                                            "mtime": int(st.st_mtime), "text": text}))
            except OSError as e:
                self._send(500, json.dumps({"error": str(e)}))
        elif p == "/api/runs":
            self._send(200, json.dumps(load_runs()))
        elif p == "/api/health":
            self._send(200, json.dumps({"ok": True, "runs": len(load_runs())}))
        elif p == "/api/overrides":
            try:
                self._send(200, json.dumps(overrides.get_overrides(store_path=Path(BASE) / "overrides.json")))
            except overrides.OverrideError as exc:
                self._send(500, json.dumps({"error": str(exc)}))
        else:
            self._send(404, "not found", "text/plain")

    def _trusted_local_request(self):
        """Loopback direct, or Tailscale Serve (proxies from loopback with a
        *.ts.net Host). Cross-site browser POSTs keep failing the Origin rule."""
        if self.client_address[0] not in ("127.0.0.1", "::1"):
            return False
        local_hosts = ("127.0.0.1", "localhost", "[::1]")
        host = self.headers.get("Host", "").split(":", 1)[0].lower()
        host_ok = host in local_hosts or host.endswith(".ts.net")
        if not host_ok:
            return False
        origin = self.headers.get("Origin")
        if origin:
            parsed = urllib.parse.urlparse(origin)
            oh = (parsed.hostname or "").lower()
            if parsed.scheme == "http" and oh in ("127.0.0.1", "localhost", "::1"):
                return True
            if parsed.scheme == "https" and oh.endswith(".ts.net") and oh == host:
                return True
            return False
        return True

    def _json_body(self):
        if not self._trusted_local_request():
            raise ValueError("local requests only")
        if not self.headers.get("Content-Type", "").lower().startswith("application/json"):
            raise ValueError("Content-Type must be application/json")
        raw = self.headers.get("Content-Length")
        if raw is None:
            if (self.headers.get("Transfer-Encoding") or "").lower() == "chunked":
                body = b""
                while True:
                    size = int(self.rfile.readline(64).split(b";")[0].strip() or b"0", 16)
                    if size == 0:
                        self.rfile.readline()
                        break
                    if len(body) + size > 512 * 1024:
                        raise ValueError("body too large")
                    body += self.rfile.read(size)
                    self.rfile.readline()
                try:
                    return json.loads(body or b"{}")
                except json.JSONDecodeError as exc:
                    raise ValueError(f"invalid JSON body: {exc}") from exc
            raise ValueError("Content-Length required")
        try:
            size = int(raw)
        except ValueError as exc:
            raise ValueError("invalid Content-Length") from exc
        if size < 0 or size > 8192:
            raise ValueError("request body must be at most 8192 bytes")
        try:
            data = json.loads(self.rfile.read(size) or b"{}")
        except (UnicodeDecodeError, json.JSONDecodeError) as exc:
            raise ValueError("bad json") from exc
        if not isinstance(data, dict):
            raise ValueError("request body must be a JSON object")
        return data

    def do_POST(self):
        if self.headers.get("Sec-Fetch-Site", "").strip().lower() == "cross-site":
            return self._send(403, json.dumps({"error": "cross-site POSTs are not allowed"}))
        p = urllib.parse.urlparse(self.path).path
        try:
            data = self._json_body()
        except ValueError as exc:
            return self._send(400, json.dumps({"error": str(exc)}))
        rid = os.path.basename(str(data.get("id", "")))  # sanitize: no path traversal
        if p == "/api/answer":
            if not rid:
                return self._send(400, json.dumps({"error": "id required"}))
            os.makedirs(ANS, exist_ok=True)
            with open(os.path.join(ANS, rid + ".json"), "w") as fh:
                json.dump({"choice": data.get("choice"), "at": int(time.time())}, fh)
            self._send(200, json.dumps({"ok": True}))
        elif p == "/api/restart":
            self._send(*restart_or_kill(rid))
        elif p == "/api/kill":
            self._send(*restart_or_kill(rid, kill_only=True))
        elif p == "/api/overrides":
            try:
                self._send(200, json.dumps({"override": overrides.set_override(
                    data, store_path=Path(BASE) / "overrides.json")}))
            except overrides.OverrideError as exc:
                self._send(400, json.dumps({"error": str(exc)}))
        elif p == "/api/overrides/clear":
            try:
                overrides.clear_overrides(role=data.get("role"), store_path=Path(BASE) / "overrides.json")
                self._send(200, json.dumps({"ok": True}))
            except overrides.OverrideError as exc:
                self._send(400, json.dumps({"error": str(exc)}))
        else:
            self._send(404, "not found", "text/plain")

    def log_message(self, *a):  # quiet
        pass


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", type=int, default=int(os.environ.get("ORCH_DASH_PORT", "4600")))
    ap.add_argument("--no-exit-with-parent", action="store_true",
                    help="keep running even after the launching process (e.g. Claude Desktop) exits")
    args = ap.parse_args()
    # Self-terminate when our parent process goes away (e.g. Claude Desktop closes),
    # unless we were started already-detached (ppid==1) or told to stay up.
    ppid0 = os.getppid()
    if not args.no_exit_with_parent and ppid0 != 1:
        def _watch_parent():
            while True:
                time.sleep(3)
                if os.getppid() != ppid0:
                    os._exit(0)
        threading.Thread(target=_watch_parent, daemon=True).start()
    os.makedirs(RUNS, exist_ok=True)
    os.makedirs(ANS, exist_ok=True)
    cleanup_retained_runs()
    class Server(socketserver.ThreadingMixIn, socketserver.TCPServer):
        allow_reuse_address = True
        daemon_threads = True
    with Server(("127.0.0.1", args.port), Handler) as srv:
        print(f"orchestrate dashboard → http://localhost:{args.port}   (runs: {RUNS})")
        try:
            srv.serve_forever()
        except KeyboardInterrupt:
            pass


if __name__ == "__main__":
    main()
