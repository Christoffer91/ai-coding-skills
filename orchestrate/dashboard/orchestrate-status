#!/usr/bin/env python3
"""orchestrate-status — emit a run's live status for the dashboard.

Writes ~/.orchestrate/runs/<id>.json. Call it from the /orchestrate skill or the
driver at each step. No dependencies (Python 3 stdlib).

  orchestrate-status start  --id ID --repo R --topic T --title "…" --branch B \
                            [--planner "Opus 4.8"] [--executor "gpt-5.6-sol · medium"] \
                            [--mode supervised] [--resume-command "…"]
  orchestrate-status step   --id ID --n 1..7 --state active|done|fail|pending [--note "…"] [--actor "…"]
  orchestrate-status pr     --id ID --number N --url U [--state OPEN]
  orchestrate-status metric --id ID --key tests --value "12/12"
  orchestrate-status worker --id ID --pid PID --pid-start TOKEN --pgid PGID --cwd DIR
  orchestrate-status handoff --id ID [--baton PATH] [--review-command COMMAND]
  orchestrate-status fail   --id ID
  orchestrate-status gate   --id ID --question "…" --option "Merge & deploy:primary" --option "Leave PR open" [--kind deploy]
  orchestrate-status wait   --id ID [--timeout 0] [--interval 3]   # blocks until answered; prints choice; clears gate
  orchestrate-status done   --id ID [--status done|failed]
  orchestrate-status pause  --id ID
  orchestrate-status cancel --id ID [--reason TEXT]
  orchestrate-status checkpoint --id ID (--name NAME [--continuation ACTION] | --clear)
  orchestrate-status resume-command --id ID (--command COMMAND | --clear)
  orchestrate-status rm     --id ID
  orchestrate-status overrides set --role critique|implement [--model MODEL] [--effort EFFORT] [--provider PROVIDER] [--ttl SECONDS]
  orchestrate-status overrides get [--role critique|implement]
  orchestrate-status overrides clear [--role critique|implement]
"""
import argparse
import ast
import json
import os
import platform
import shutil
import subprocess
import sys
import time

HERE = os.path.dirname(os.path.realpath(__file__))  # resolve ~/.local/bin symlinks
if HERE not in sys.path:
    sys.path.insert(0, HERE)
import overrides

HOME = os.path.expanduser("~")
BASE = os.path.join(HOME, ".orchestrate")
RUNS = os.path.join(BASE, "runs")
ANS  = os.path.join(BASE, "answers")
STEP_NAMES = ["Plan", "Critique plan", "Implement", "Open PR", "Review PR", "Apply edits", "Deploy"]
STEP_ACTORS = ["Claude", "gpt-5.6-sol", "gpt-5.6-sol·med", "driver", "Claude", "gpt-5.6-sol·med", "gated"]
MAX_RESUME_COMMAND_LENGTH = 1000


def resume_command_arg(value):
    """Validate a secret-free, copy-only resume command for status storage."""
    if not value or not value.strip():
        raise argparse.ArgumentTypeError("resume command must not be empty")
    if len(value) > MAX_RESUME_COMMAND_LENGTH:
        raise argparse.ArgumentTypeError(
            f"resume command must be at most {MAX_RESUME_COMMAND_LENGTH} characters"
        )
    if not value.isprintable():
        raise argparse.ArgumentTypeError(
            "resume command must not contain non-printable or control characters"
        )
    return value

def path(rid):
    rid = os.path.basename(rid)
    return os.path.join(RUNS, rid + ".json")

def load(rid):
    try:
        with open(path(rid)) as fh:
            return json.load(fh)
    except Exception:
        return None

def save(r):
    os.makedirs(RUNS, exist_ok=True)
    r["updatedAt"] = int(time.time())
    target = path(r["id"])
    tmp = target + ".tmp"
    with open(tmp, "w") as fh:
        json.dump(r, fh, indent=2)
    os.replace(tmp, target)

def need(rid):
    r = load(rid)
    if r is None:
        sys.exit(f"orchestrate-status: no run '{rid}' (run `start` first)")
    return r


def _strip_toml_comment(value):
    """Strip a TOML comment without treating hashes inside quotes as comments."""
    quote = None
    escaped = False
    for index, char in enumerate(value):
        if escaped:
            escaped = False
        elif char == "\\" and quote == '"':
            escaped = True
        elif quote:
            if char == quote:
                quote = None
        elif char in "'\"":
            quote = char
        elif char == "#":
            return value[:index].rstrip()
    return value.strip()


def _notify_from_toml(cwd):
    """Read only notify_cmd from the repo-local config on Python 3.9+.

    The supported value is a TOML/Python-compatible quoted string or array of
    strings.  ast.literal_eval is deliberately used instead of executing config.
    """
    if not cwd:
        return None
    config = os.path.join(cwd, ".ai", "orchestrate.toml")
    try:
        with open(config, encoding="utf-8") as fh:
            lines = fh.readlines()
    except OSError:
        return None
    in_top_level = True
    for line in lines:
        if line.lstrip().startswith("["):
            in_top_level = False
        if not in_top_level:
            continue
        key, sep, raw = line.partition("=")
        if not sep or key.strip() != "notify_cmd":
            continue
        try:
            value = ast.literal_eval(_strip_toml_comment(raw))
        except (SyntaxError, ValueError):
            return None
        if isinstance(value, str) and value:
            return [value]
        if isinstance(value, list) and value and all(isinstance(item, str) and item for item in value):
            return value
        return None
    return None


def notify(r, message):
    """Invoke one bounded, non-shell notification hook; failures are non-fatal."""
    if os.environ.get("ORCH_NOTIFY_DISABLE") == "1":
        return
    env_cmd = os.environ.get("ORCH_NOTIFY_CMD")
    config_root = r.get("repoRoot") or r.get("cwd") or os.getcwd()
    argv = [env_cmd] if env_cmd else _notify_from_toml(config_root)
    if not argv and platform.system() == "Darwin" and shutil.which("osascript"):
        argv = [
            "osascript", "-e", "on run argv", "-e",
            'display notification (item 1 of argv) with title "orchestrate"',
            "-e", "end run", "--",
        ]
    if not argv:
        return
    executable = shutil.which(argv[0]) if os.path.sep not in argv[0] else argv[0]
    if not executable or not os.path.isfile(executable) or not os.access(executable, os.X_OK):
        return
    argv[0] = executable
    try:
        subprocess.run(
            argv + [message], check=False, stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL, timeout=10,
        )
    except (OSError, subprocess.TimeoutExpired):
        pass

def main():
    ap = argparse.ArgumentParser(add_help=True)
    sub = ap.add_subparsers(dest="cmd", required=True)
    def common(p): p.add_argument("--id", required=True)

    p = sub.add_parser("start"); common(p)
    for f in ("repo", "topic", "title", "branch"): p.add_argument("--" + f, required=True)
    p.add_argument("--planner", default="Claude"); p.add_argument("--executor", default="gpt-5.6-sol · medium")
    p.add_argument("--mode", default="hands-off"); p.add_argument("--pid", type=int, default=None)
    p.add_argument("--cwd", default=None); p.add_argument("--repo-root", default=None)
    p.add_argument("--driver", default=None)  # for one-click restart
    p.add_argument("--pid-start", default=None); p.add_argument("--pgid", type=int, default=None)
    p.add_argument("--plan", default=None); p.add_argument("--worktree", action="store_true")
    p.add_argument("--resume-command", type=resume_command_arg, default=None)
    p.add_argument("--env", action="append", default=[])

    p = sub.add_parser("step"); common(p)
    p.add_argument("--n", type=int, required=True); p.add_argument("--state", required=True)
    p.add_argument("--note", default=None); p.add_argument("--actor", default=None); p.add_argument("--pid", type=int, default=None)

    p = sub.add_parser("pr"); common(p)
    p.add_argument("--number", required=True); p.add_argument("--url", required=True); p.add_argument("--state", default="OPEN")

    p = sub.add_parser("metric"); common(p); p.add_argument("--key", required=True); p.add_argument("--value", required=True)

    p = sub.add_parser("worker"); common(p)
    p.add_argument("--pid", type=int, required=True); p.add_argument("--pid-start", required=True)
    p.add_argument("--pgid", type=int, required=True); p.add_argument("--cwd", required=True)

    p = sub.add_parser("gate"); common(p)
    p.add_argument("--question", required=True); p.add_argument("--kind", default="gate")
    p.add_argument("--option", action="append", default=[], required=True)
    p.add_argument("--checkpoint", default=None); p.add_argument("--continuation", default=None)

    p = sub.add_parser("wait"); common(p)
    p.add_argument("--timeout", type=int, default=0); p.add_argument("--interval", type=float, default=3.0)

    p = sub.add_parser("done"); common(p); p.add_argument("--status", default="done")
    p = sub.add_parser("handoff"); common(p)
    p.add_argument("--baton", default=None); p.add_argument("--review-command", default=None)
    p.add_argument("--max-iterations", type=int, default=3)
    p = sub.add_parser("fail"); common(p)
    p = sub.add_parser("pause"); common(p)
    p = sub.add_parser("cancel"); common(p); p.add_argument("--reason", default="rejected")
    p = sub.add_parser("checkpoint"); common(p)
    p.add_argument("--name", default=None); p.add_argument("--continuation", default=None)
    p.add_argument("--clear", action="store_true")
    p = sub.add_parser("resume-command"); common(p)
    resume = p.add_mutually_exclusive_group(required=True)
    resume.add_argument("--command", type=resume_command_arg)
    resume.add_argument("--clear", action="store_true")
    p = sub.add_parser("rm"); common(p)
    p = sub.add_parser("heartbeat"); common(p); p.add_argument("--pid", type=int, default=None)
    p = sub.add_parser("execution"); common(p)
    p.add_argument("--role", choices=overrides.ROLES, required=True)
    p.add_argument("--provider", choices=overrides.PROVIDERS, required=True)
    p.add_argument("--model", default=None); p.add_argument("--effort", default=None)
    p.add_argument("--source", choices=("config", "env", "default", "override"), required=True)
    p.add_argument("--override-id", default=None); p.add_argument("--set-at", type=int, default=None)
    p.add_argument("--expires-at", type=int, default=None); p.add_argument("--fallback", action="store_true")
    p = sub.add_parser("overrides")
    override_sub = p.add_subparsers(dest="override_cmd", required=True)
    q = override_sub.add_parser("set")
    q.add_argument("--role", required=True); q.add_argument("--model", default=None)
    q.add_argument("--effort", default=None); q.add_argument("--provider", default=None)
    q.add_argument("--ttl", type=int, default=None)
    q = override_sub.add_parser("get"); q.add_argument("--role", default=None)
    q = override_sub.add_parser("clear"); q.add_argument("--role", default=None)

    a = ap.parse_args()

    if a.cmd == "overrides":
        try:
            if a.override_cmd == "set":
                payload = {key: value for key, value in vars(a).items()
                           if key in ("role", "model", "effort", "provider", "ttl") and value is not None}
                print(json.dumps(overrides.set_override(payload), separators=(",", ":")))
            elif a.override_cmd == "get":
                print(json.dumps(overrides.get_overrides(role=a.role), separators=(",", ":")))
            else:
                overrides.clear_overrides(role=a.role)
                print(json.dumps({"ok": True}, separators=(",", ":")))
        except overrides.OverrideError as exc:
            sys.exit(f"orchestrate-status: {exc}")

    elif a.cmd == "start":
        restart_env = {}
        for item in a.env:
            key, sep, value = item.partition("=")
            if sep and key.startswith("ORCH_"):
                restart_env[key] = value
        steps = [{"n": i + 1, "name": STEP_NAMES[i], "actor": STEP_ACTORS[i],
                  "state": "active" if i == 0 else "pending"} for i in range(7)]
        save({"id": os.path.basename(a.id), "repo": a.repo, "topic": a.topic, "title": a.title,
              "branch": a.branch, "planner": a.planner, "executor": a.executor, "mode": a.mode,
              "startedAt": int(time.time()), "step": 1, "status": "running", "pid": a.pid,
              "cwd": a.cwd, "repoRoot": a.repo_root or a.cwd, "driver": a.driver,
              "pidStart": a.pid_start, "pgid": a.pgid,
              "pidCwd": a.cwd, "worker": None,
              "resumeCommand": a.resume_command,
              "restart": {"plan": a.plan, "dedicatedWorktree": a.worktree, "env": restart_env},
              "pr": None, "metrics": {}, "gate": None, "steps": steps})

    elif a.cmd == "step":
        r = need(a.id); i = a.n - 1
        if not (0 <= i < 7): sys.exit("--n must be 1..7")
        now = int(time.time())
        prev = r["steps"][i].get("state")
        if a.state == "active" and prev != "active":
            r["steps"][i]["startedAt"] = now
        elif a.state in ("done", "fail") and prev == "active":
            r["steps"][i]["endedAt"] = now
        r["steps"][i]["state"] = a.state
        if a.note is not None: r["steps"][i]["note"] = a.note
        if a.actor: r["steps"][i]["actor"] = a.actor
        r["step"] = a.n
        if a.pid: r["pid"] = a.pid
        if r.get("status") not in ("await", "done", "failed"):
            r["status"] = "review" if (a.n == 6 and a.state == "active") else \
                          "fail" if a.state == "fail" else "running"
        save(r)

    elif a.cmd == "pr":
        r = need(a.id); r["pr"] = {"number": a.number, "url": a.url, "state": a.state}; save(r)

    elif a.cmd == "metric":
        r = need(a.id); r.setdefault("metrics", {})[a.key] = a.value; save(r)

    elif a.cmd == "execution":
        r = need(a.id)
        entry = {"provider": a.provider, "source": a.source, "fallback": bool(a.fallback)}
        for key, value in (("model", a.model), ("effort", a.effort), ("overrideId", a.override_id),
                           ("setAt", a.set_at), ("expiresAt", a.expires_at)):
            if value is not None:
                entry[key] = value
        r.setdefault("execution", {})[a.role] = entry
        save(r)

    elif a.cmd == "worker":
        r = need(a.id)
        r["worker"] = {"pid": a.pid, "startedAt": a.pid_start, "pgid": a.pgid, "cwd": a.cwd}
        save(r)

    elif a.cmd == "gate":
        r = need(a.id)
        opts = []
        for o in a.option:
            lbl, _, tag = o.partition(":")
            opts.append({"label": lbl, "primary": tag.strip() == "primary"})
        r["gate"] = {"kind": a.kind, "question": a.question, "options": opts}
        r["lastGateAnswer"] = None
        if a.checkpoint:
            r["checkpoint"] = {"name": a.checkpoint, "continuation": a.continuation}
        r["status"] = "await"
        # clear any stale answer so this gate waits fresh
        af = os.path.join(ANS, os.path.basename(a.id) + ".json")
        if os.path.exists(af):
            try: os.remove(af)
            except OSError: pass
        save(r)
        notify(r, f"orchestrate {r.get('repo')}/{r.get('topic')} needs you: {a.question}")

    elif a.cmd == "wait":
        af = os.path.join(ANS, os.path.basename(a.id) + ".json")
        deadline = time.time() + a.timeout if a.timeout > 0 else None
        while True:
            if os.path.exists(af):
                try:
                    with open(af) as fh: ans = json.load(fh)
                except Exception:
                    ans = {}
                choice = ans.get("choice", "")
                r = load(a.id)
                labels = {o.get("label") for o in ((r or {}).get("gate") or {}).get("options", [])}
                if not r or choice not in labels:
                    print(f"orchestrate-status: invalid gate choice {choice!r}; waiting for one of {sorted(labels)!r}", file=sys.stderr)
                    try: os.remove(af)
                    except OSError: pass
                    continue
                if r:
                    r["lastGateAnswer"] = {"kind": (r.get("gate") or {}).get("kind"), "choice": choice}
                    r["gate"] = None
                    if r.get("status") == "await": r["status"] = "running"
                    save(r)
                try: os.remove(af)  # consume
                except OSError: pass
                print(choice)  # caller reads the choice from stdout
                return
            if deadline and time.time() > deadline:
                sys.exit(2)  # timed out, not answered
            time.sleep(a.interval)

    elif a.cmd == "done":
        r = need(a.id)
        r["steps"][6]["state"] = "done" if a.status == "done" else "fail"
        r["step"] = 7; r["status"] = a.status; r["gate"] = None; save(r)

    elif a.cmd == "handoff":
        r = need(a.id)
        r["status"] = "handoff"; r["pid"] = None; r["worker"] = None; r["gate"] = None
        r["checkpoint"] = None
        r["review"] = {"baton": a.baton, "command": a.review_command,
                       "iteration": 0, "maxIterations": a.max_iterations}
        save(r)
        pr_number = (r.get("pr") or {}).get("number", "?")
        command = a.review_command or f"/orchestrate review {r.get('topic')}"
        notify(r, f"PR #{pr_number} ready for review — run: {command}")

    elif a.cmd == "fail":
        r = need(a.id)
        i = max(0, min(len(r.get("steps", [])) - 1, int(r.get("step", 1)) - 1))
        if r.get("steps"): r["steps"][i]["state"] = "fail"
        r["status"] = "failed"; r["gate"] = None; r["worker"] = None
        save(r)
        notify(r, f"orchestrate {r.get('repo')}/{r.get('topic')} failed at step {r.get('step', 1)}")

    elif a.cmd == "pause":
        r = need(a.id)
        r["pid"] = None; r["worker"] = None
        save(r)

    elif a.cmd == "cancel":
        r = need(a.id)
        r["status"] = "rejected"; r["pid"] = None; r["worker"] = None; r["gate"] = None
        r["checkpoint"] = None; r["reason"] = a.reason
        save(r)

    elif a.cmd == "checkpoint":
        r = need(a.id)
        if a.clear:
            r["checkpoint"] = None
        elif a.name:
            r["checkpoint"] = {"name": a.name, "continuation": a.continuation}
        else:
            sys.exit("checkpoint requires --name or --clear")
        save(r)

    elif a.cmd == "resume-command":
        r = need(a.id)
        r["resumeCommand"] = None if a.clear else a.command
        save(r)

    elif a.cmd == "heartbeat":
        r = need(a.id)
        if a.pid: r["pid"] = a.pid
        save(r)  # bumps updatedAt to signal liveness

    elif a.cmd == "rm":
        for d in (RUNS, ANS):
            f = os.path.join(d, os.path.basename(a.id) + ".json")
            if os.path.exists(f): os.remove(f)

if __name__ == "__main__":
    main()
