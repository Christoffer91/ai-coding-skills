#!/usr/bin/env python3
"""orchestrate-watchdog — reap orphaned/hung Codex and flag runs that need a restart.

Companion to the driver's built-in auto-recovery, for the cases the driver can't
reach: a run whose whole driver process died, or an in-session run that stalled.
It DETECTS (stalled/exited), REAPS only the exact recorded Codex worker, and
ESCALATES (marks the run `needsRestart` + logs to
~/.orchestrate/watchdog.log). It does NOT redispatch — use the dashboard's
Restart button or re-run the topic manually.

Usage:  orchestrate-watchdog [--poll 30] [--grace 180] [--once]
Env:    ORCH_STALE_SECS (default 75), ORCH_WATCH_POLL, ORCH_WATCH_GRACE
No dependencies (Python 3 stdlib). Safe to run alongside the dashboard.
"""
import os, glob, json, time, signal, subprocess, argparse, sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))  # resolve ~/.local/bin symlink
import thresholds

HOME = os.path.expanduser("~")
BASE = os.path.join(HOME, ".orchestrate")
RUNS = os.path.join(BASE, "runs")
ANS  = os.path.join(BASE, "answers")
LOG  = os.path.join(BASE, "watchdog.log")


def pid_alive(pid):
    if not pid:
        return None
    try:
        os.kill(int(pid), 0); return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except Exception:
        return None


def process_start(pid):
    try:
        return subprocess.run(["ps", "-o", "lstart=", "-p", str(int(pid))], capture_output=True,
                              text=True, timeout=3).stdout.strip() or None
    except Exception:
        return None


def process_cwd(pid):
    try:
        out = subprocess.run(["lsof", "-a", "-p", str(int(pid)), "-d", "cwd", "-Fn"],
                             capture_output=True, text=True, timeout=3).stdout
        return next((line[1:] for line in out.splitlines() if line.startswith("n")), None)
    except Exception:
        return None


def process_matches(worker):
    pid, expected_start, expected_cwd = worker.get("pid"), worker.get("startedAt"), worker.get("cwd")
    if not (pid and expected_start and expected_cwd):
        return False
    actual_cwd = process_cwd(pid)
    return (process_start(pid) == expected_start and actual_cwd is not None
            and os.path.realpath(actual_cwd) == os.path.realpath(expected_cwd))


def start_epoch(token):
    try:
        return int(time.mktime(time.strptime(token, "%a %b %d %H:%M:%S %Y")))
    except (TypeError, ValueError):
        return None


def reap_recorded_worker(run):
    """Reap only an identity-matched worker that began after its owning run."""
    worker = run.get("worker") or {}
    if not process_matches(worker):
        return []
    began = start_epoch(worker.get("startedAt"))
    run_began = run.get("startedAt")
    if run_began is not None and (began is None or began < int(run_began)):
        return []
    pid = int(worker["pid"])
    try:
        pgid = os.getpgid(pid)
        if pgid == pid and int(worker.get("pgid") or -1) == pid:
            os.killpg(pgid, signal.SIGKILL)
        else:
            os.kill(pid, signal.SIGKILL)
        return [pid]
    except Exception:
        return []


def save(r):
    target = os.path.join(RUNS, os.path.basename(r["id"]) + ".json")
    tmp = target + ".tmp"
    with open(tmp, "w") as fh:
        json.dump(r, fh, indent=2)
    os.replace(tmp, target)


def logline(msg):
    stamp = time.strftime("%Y-%m-%d %H:%M:%S")
    print(f"{stamp} {msg}", flush=True)
    try:
        with open(LOG, "a") as fh:
            fh.write(f"{stamp} {msg}\n")
    except Exception:
        pass


def sweep(grace, handled):
    now = int(time.time())
    for f in glob.glob(os.path.join(RUNS, "*.json")):
        try:
            with open(f) as fh: r = json.load(fh)
        except Exception:
            continue
        status = r.get("status")
        if status in ("done", "failed", "fail", "handoff", "await", "paused", "rejected"):
            continue
        answered = os.path.exists(os.path.join(ANS, os.path.basename(f)))
        if r.get("gate") and not answered:
            continue  # waiting on a human — not a liveness concern
        age = now - int(r.get("updatedAt", now))
        alive = pid_alive(r.get("pid"))
        dead = alive is False
        stalled = age > grace
        # A no-pid model-driven run (Codex goal / in-session) that emits only at transitions has no
        # worker to reap and no evidence of a hang — its silence is "quiet", not "needsRestart".
        # Only act when there is a real worker: a live/dead pid or a recorded reapable worker.
        has_worker = bool(r.get("pid")) or bool((r.get("worker") or {}).get("pid"))
        if not (dead or (stalled and has_worker)):
            continue
        if handled.get(r["id"]) == r.get("updatedAt"):
            continue  # already escalated this exact state
        reaped = reap_recorded_worker(r)
        r["needsRestart"] = True
        r["watchdog"] = {"at": now, "reason": "exited" if dead else "stalled", "reaped": reaped}
        save(r)
        handled[r["id"]] = r.get("updatedAt")
        logline(f"{r['id']}: {'worker exited' if dead else f'stalled {age}s'}; "
                f"reaped codex {reaped or '(none)'}; flagged needsRestart")


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--poll", type=int, default=int(os.environ.get("ORCH_WATCH_POLL", "30")))
    ap.add_argument("--grace", type=int, default=thresholds.WATCHDOG_GRACE_SECS)
    ap.add_argument("--once", action="store_true", help="one sweep then exit (for cron/testing)")
    a = ap.parse_args()
    os.makedirs(RUNS, exist_ok=True)
    handled = {}
    ppid0 = os.getppid()  # exit when our launcher (e.g. Claude Desktop) goes away
    logline(f"watchdog up (poll={a.poll}s grace={a.grace}s once={a.once})")
    while True:
        if not a.once and ppid0 != 1 and os.getppid() != ppid0:
            logline("launching process exited — watchdog stopping"); return
        try:
            sweep(a.grace, handled)
        except Exception as e:
            logline(f"sweep error: {e}")
        if a.once:
            return
        time.sleep(a.poll)


if __name__ == "__main__":
    main()
