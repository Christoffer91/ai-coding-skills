# Per-repo /orchestrate config. Copy to <repo>/.ai/orchestrate.toml and keep it
# secret-free. Every key is optional; safe defaults apply when absent.

# Auto-deploy stays HUMAN-GATED unless a person sets this to true. An agent must
# never write or change this authorization.
deploy_authorized = false

# Independent pre-push verification. Prefer argv arrays: commands execute
# directly, never through a shell. Quoted strings use shlex splitting, so pipes,
# redirects, globs, and environment assignments are not shell syntax here.
# Uncomment only commands that exist in this trusted local checkout.
#
# COST TIP (private repos): these run LOCALLY before push. Filling them in is the
# main lever for keeping GitHub Actions minutes low — the loop catches failures
# here instead of pushing broken commits that trigger your remote CI. Pair with a
# `concurrency: cancel-in-progress` block in the target repo's workflows so the
# fix loop's later pushes cancel superseded runs. See references/auto-deploy-safety.md.
# test_cmd  = ["python3", "-m", "unittest", "discover", "-s", "tests", "-v"]
# build_cmd = ["npm", "run", "build"]
# eval_cmd  = ["python3", "scripts/eval.py"]

# deploy_cmd   = "npm run deploy"
# deploy_skill = "your-deploy-skill"
# deploy_via   = "git-merge"
# auto_merge   = false

ci_gate     = true
max_iter    = 3
sandbox     = "workspace-write"
exec_effort = "medium"

# Optional notification hook. Prefer an argv array when fixed arguments are
# needed. The status emitter appends the message as one final argument, enforces
# a 10-second timeout, and never invokes a shell. Never put tokens here; let the
# hook obtain credentials from the keychain or its own protected environment.
# notify_cmd = "/absolute/path/to/phone-notify-hook"
# notify_cmd = ["/absolute/path/to/phone-notify-hook", "--channel", "orchestrate"]
