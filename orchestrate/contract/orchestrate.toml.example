# Per-repo /orchestrate config. Copy to <repo>/.ai/orchestrate.toml and keep it
# secret-free. Every key is optional; safe defaults apply when absent.

# Auto-deploy stays HUMAN-GATED unless a person sets this to true. An agent must
# never write or change this authorization.
deploy_authorized = false

# deploy_cmd   = "npm run deploy"
# deploy_skill = "your-deploy-skill"
# deploy_via   = "git-merge"
# auto_merge   = false

ci_gate     = true
max_iter    = 3
sandbox     = "workspace-write"
exec_effort = "medium"

# Optional notification hook. Prefer an argv array when fixed arguments are
# needed. The status emitter appends the message as one final argument, enforces
# a 10-second timeout, and never invokes a shell. Never put tokens here; let the
# hook obtain credentials from the keychain or its own protected environment.
# notify_cmd = "/absolute/path/to/phone-notify-hook"
# notify_cmd = ["/absolute/path/to/phone-notify-hook", "--channel", "orchestrate"]
